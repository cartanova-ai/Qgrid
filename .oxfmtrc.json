{
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortImports": true,
  "ignorePatterns": [
    "**/dist",
    "**/build",
    "**/node_modules",
    "**/*.gen.ts",
    "**/*.generated.ts",
    "**/*.generated.tsx",
    "**/*.mdx",
    "**/*.md"
  ]
}
